# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# API Keys & Tokens
OPENAI_API_KEY=your_openai_api_key_here
XAI_API_KEY=your_xai_api_key_here
GITHUB_TOKEN=your_github_token_here

# Digibib Dortmund (Stadt- und Landesbibliothek)
DIGIBIB_BARCODE=your_library_card_number_here
DIGIBIB_PASSWORD=your_library_password_or_pin_here

# Scribd Premium/Session configuration
SCRIBD_USER=your_scribd_username_here
SCRIBD_PASS=your_scribd_password_here
SCRIBD_COOKIE=optional_raw_session_cookie_value_here

# Statista Credentials or session cookies
STATISTA_USER=your_statista_username_here
STATISTA_PASS=your_statista_password_here
STATISTA_COOKIE=optional_raw_session_cookie_value_here

# LinkedIn Session Configuration (Crucial to bypass scraping blocks)
LINKEDIN_COOKIE_LI_AT=your_li_at_cookie_value_here

# Dortmund Open Data API
DORTMUND_OPEN_DATA_KEY=optional_api_key_here
