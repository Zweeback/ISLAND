{
  "project_name": "blast_agent",
  "version": "1.0.0",
  "root_path": ".",
  "components": {
    "orchestrator": {
      "file": "blast_agent.py",
      "dependencies": [
        "tools/agent_loop.py"
      ]
    },
    "scrapers": {
      "opendata_dortmund": {
        "file": "tools/scraper_opendata_dortmund.py",
        "api_endpoint": "https://open-data.dortmund.de/api/explore/v2.1"
      },
      "digibib": {
        "file": "tools/scraper_digibib.py",
        "api_endpoint": "https://lobid.org/",
        "web_portal": "https://stlb-dortmund.digibib.net/"
      },
      "scribd": {
        "file": "tools/scraper_scribd.py",
        "web_portal": "https://www.scribd.com/"
      },
      "statista": {
        "file": "tools/scraper_statista.py",
        "web_portal": "https://de.statista.com/"
      },
      "linkedin": {
        "file": "tools/scraper_linkedin.py",
        "web_portal": "https://www.linkedin.com/"
      }
    },
    "inventory": {
