# B.L.A.S.T. Environment Configuration Template
# Ersetze die Platzhalter mit deinen echten Secrets. Diese Datei DARF auf GitHub landen.

OPENAI_API_KEY=sk-proj-PLACEHOLDER_SECRET_KEY
GITHUB_TOKEN=ghp_PLACEHOLDER_TOKEN
BLAST_SCAN_PATH=""
BLAST_LLM_MODEL=gpt-4o-mini

# Digibib Dortmund Credentials
DIGIBIB_BARCODE=your_barcode_here
DIGIBIB_PASSWORD=your_password_here

# Scribd API / Cookie
SCRIBD_USER=username
SCRIBD_PASS=password
SCRIBD_COOKIE=cookie_string_here

# Statista Credentials
STATISTA_USER=username
STATISTA_PASS=password
STATISTA_COOKIE=cookie_string_here

# LinkedIn Cookie
LINKEDIN_COOKIE_LI_AT=li_at_cookie_string

# Dortmund Open Data
DORTMUND_OPEN_DATA_KEY=api_key_here
